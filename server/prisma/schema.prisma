generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Multi-tenancy ───

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  deals          Deal[]
  pipelineStages PipelineStage[]
  savedViews     SavedView[]
  customFields   CustomField[]
  customKpis     CustomKpiDef[]
  goals          GoalDef[]
  widgetConfigs  WidgetConfig[]
  customers      Customer[]
  chatSessions   ChatSession[]
  lifecycleStages CustomerLifecycleStage[]
  contracts       Contract[]
}

// ─── Auth ───

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("MEMBER") // OWNER, ADMIN, MEMBER
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens RefreshToken[]
  activityLogs  ActivityLog[]
  assignedDeals Deal[]     @relation("DealManager")

  @@index([workspaceId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Core: Deals ───

model Deal {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  company   String
  stageId   String
  stage     PipelineStage @relation(fields: [stageId], references: [id])
  contact   String @default("")
  position  String @default("")
  service   String @default("")
  quantity  Int    @default(0)
  amount    Int    @default(0) // 만원 단위
  managerId String?
  manager   User?  @relation("DealManager", fields: [managerId], references: [id])
  status    String @default("IN_PROGRESS") // IN_PROGRESS, WON, LOST
  date      DateTime @default(now())
  phone     String @default("")
  email     String @default("")
  memo      String @default("")

  customFieldValues String @default("{}") // JSON string

  customerId String?
  customer   Customer? @relation("CustomerSourceDeals", fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs  ActivityLog[]
  attachedFiles AttachedFile[]

  @@index([workspaceId])
  @@index([workspaceId, stageId])
  @@index([workspaceId, status])
  @@index([workspaceId, date])
  @@index([customerId])
}

// ─── Pipeline Stages ───

model PipelineStage {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  color       String   @default("#3B82F6")
  type        String   @default("ACTIVE") // ACTIVE, WON, LOST
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals Deal[]

  @@index([workspaceId])
}

// ─── Saved Views ───

model SavedView {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  viewType    String   // table, kanban, timeline
  filters     String   @default("[]")
  sorts       String   @default("[]")
  groupBy     String   @default("")
  searchQuery String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

// ─── Custom Fields ───

model CustomField {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  key         String
  label       String
  type        String   // text, number, select, multi-select, date, person, phone, email, file
  required    Boolean  @default(false)
  locked      Boolean  @default(false)
  options     String   @default("[]") // JSON
  visible     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@unique([workspaceId, key])
}

// ─── Custom KPIs ───

model CustomKpiDef {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  formula     String
  numerator   String?
  denominator String?
  suffix      String   @default("%")
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

// ─── Goals ───

model GoalDef {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  name         String
  targetAmount Int      // 만원 단위
  period       String   // monthly, quarterly
  createdAt    DateTime @default(now())

  @@index([workspaceId])
}

// ─── Widget Config ───

model WidgetConfig {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  widgetOrder String   @default("[]")
  widgetSizes String   @default("{}")
  updatedAt   DateTime @updatedAt
}

// ─── Activity Logs ───

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type        String   // stage_change, memo, email, call, file, created
  title       String
  detail      String   @default("")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([dealId])
  @@index([workspaceId, dealId])
}

// ─── Attached Files ───

model AttachedFile {
  id          String   @id @default(cuid())
  workspaceId String
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  name        String
  type        String   // 견적서, 계약서, 제안서, 기타
  size        Int
  storagePath String
  mimeType    String   @default("")
  createdAt   DateTime @default(now())

  @@index([dealId])
}

// ─── Customers ───

model Customer {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  avatar      String   @default("")
  title       String   @default("")
  company     String   @default("")
  status      String   @default("활성")
  email       String   @default("")
  phone       String   @default("")
  location    String   @default("")

  lifecycleStageId String?
  lifecycleStage   CustomerLifecycleStage? @relation(fields: [lifecycleStageId], references: [id])
  healthScore      Int     @default(70)
  customFieldValues String @default("{}") // JSON

  sourceDeals Deal[]     @relation("CustomerSourceDeals")
  contracts   Contract[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, lifecycleStageId])
}

// ─── Customer Lifecycle Stages ───

model CustomerLifecycleStage {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  color       String   @default("#3B82F6")
  type        String   @default("ACTIVE") // ONBOARDING, ACTIVE, DORMANT, CHURNED
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]

  @@index([workspaceId])
}

// ─── Contracts ───

model Contract {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  amount      Int      @default(0) // 만원
  status      String   @default("ACTIVE") // ACTIVE, RENEWED, EXPIRED, CHURNED
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([customerId])
}

// ─── Chat ───

model ChatSession {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  title       String   @default("새 대화")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ChatMessage[]

  @@index([workspaceId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user, assistant
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId])
}
